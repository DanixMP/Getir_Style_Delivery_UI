# Django
SECRET_KEY=your-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=getir_style_delivery_ui_db
POSTGRES_USER=getir_style_delivery_ui_user
POSTGRES_PASSWORD=getir_style_delivery_ui_pass
DATABASE_URL=postgres://getir_style_delivery_ui_user:getir_style_delivery_ui_pass@localhost:5432/getir_style_delivery_ui_db

# Redis
REDIS_URL=redis://localhost:6379/0

# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_RECORDING_ENABLED=false

# Zarinpal
ZARINPAL_MERCHANT_ID=your-merchant-id
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL=https://yourdomain.com/api/v1/payments/verify/

# Firebase
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json

# Arvan Cloud S3
ARVAN_ACCESS_KEY=your-access-key
ARVAN_SECRET_KEY=your-secret-key
ARVAN_BUCKET_NAME=getir_style_delivery_ui-media
ARVAN_ENDPOINT_URL=https://s3.ir-thr-at1.arvanstorage.ir
ARVAN_REGION=ir-thr-at1

# Neshan
NESHAN_API_KEY=your-neshan-key

# Developer Kill Switch
DEVELOPER_SECRET_KEY=very-long-random-string-only-you-know
KILL_SWITCH_ACTIVE=false

# Developer bootstrap user (used by create_developer_user command)
DEVELOPER_PHONE=09120000000
DEVELOPER_PASSWORD=change-me-now
